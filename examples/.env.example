# mcp-server-email environment variables
# Copy to .env and modify as needed.

# --- Required (one of these) ---
EMAIL_CONFIG_FILE=~/.config/mcp-email/accounts.json
# EMAIL_ACCOUNTS='[{"id":"main","email":"user@example.com","imap_host":"mail.example.com","imap_port":993,"smtp_host":"mail.example.com","smtp_port":465,"username":"user@example.com","password":"app-password"}]'

# --- Optional ---
# EMAIL_DEFAULT_ACCOUNT=main
# EMAIL_IMAP_TIMEOUT_MS=30000
# EMAIL_SMTP_TIMEOUT_MS=30000
# EMAIL_IMAP_RATE_LIMIT=60
# EMAIL_SMTP_RATE_LIMIT=100
# MAX_ATTACHMENT_SIZE_MB=18
# MAX_TOTAL_ATTACHMENT_SIZE_MB=18
# MAX_DOWNLOAD_SIZE_MB=25
# EMAIL_POOL_CLOSE_TIMEOUT_MS=5000

# --- Logging ---
# LOG_LEVEL=info
# LOG_FORMAT=json
# EMAIL_DEBUG=false
